<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- 
    Purpose: TestNG Suite Configuration
    This file defines the test suite structure and execution parameters
    for the UI Test Automation Framework
-->

<suite name="SauceDemo Test Suite" parallel="tests" thread-count="3" verbose="1">
    
    <!-- Suite-level parameters -->
    <parameter name="browser" value="chrome"/>
    
    <!-- Listeners for Allure reporting -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    
    <!-- Test: Login Features -->
    <test name="Login Tests">
        <classes>
            <class name="com.saucedemo.runners.TestRunner"/>
        </classes>
    </test>
    
</suite>
